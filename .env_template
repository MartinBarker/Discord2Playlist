# ── Discord ────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_TOKEN=
# Only needed for `npm run deploy:guild` (instant command updates on a test server)
DISCORD_GUILD_ID=

# ── Google / YouTube OAuth ───────────────────────────────────────────────────
GCP_CLIENT_ID=
GCP_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI in the Google Cloud console.
# Local:  http://localhost:3000/api/youtube/oauth/callback
# Prod:   https://bot.martinbarker.me/api/youtube/oauth/callback
OAUTH_REDIRECT_URL=http://localhost:3000/api/youtube/oauth/callback
# Public base URL of THIS bot's API (used to build OAUTH_REDIRECT_URL if unset).
BOT_PUBLIC_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# postgresql://user:password@host:5432/discord2playlist
DATABASE_URL=

# ── Secrets ──────────────────────────────────────────────────────────────────
# Signs magic links + OAuth state. Generate with: openssl rand -hex 32
SCAN_SECRET=
# Authenticates martinbarker.me's server-side calls to this API. openssl rand -hex 32
SITE_SHARED_SECRET=
# Optional: dedicated key for encrypting YouTube refresh tokens at rest.
# Falls back to SCAN_SECRET if unset. openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Server / site ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Where the results page lives (used to build magic links posted to Discord).
SITE_ORIGIN=https://martinbarker.me
